{
  "name": "mool-gyan-app",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9002",
    "build": "next build",
    "start": "next start",
    "postbuild": "rimraf \"dist/cache\" \"dist/.next\"",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules .next package-lock.json",
    "reset": "npm run clean && npm install",
    "cap:init": "npx cap init \"Mool Gyan\" \"com.moolgyan.app\"",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:prepare:android": "npm run build && npx cap copy android",
    "cap:run:android": "npm run cap:prepare:android && npx cap run android",
    "cap:build:apk": "npm run cap:prepare:android && cd android && gradlew assembleRelease",
    "preview": "npx serve dist",
    "deploy:static": "npm run build && npm run postbuild && npx wrangler pages deploy dist --project-name=mool-gyan-app"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@hookform/resolvers": "3.3.4",
    "@netlify/plugin-nextjs": "^5.15.8",
    "@radix-ui/react-accordion": "1.1.2",
    "@radix-ui/react-alert-dialog": "1.0.5",
    "@radix-ui/react-avatar": "1.0.4",
    "@radix-ui/react-checkbox": "1.0.4",
    "@radix-ui/react-collapsible": "1.0.3",
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "2.0.2",
    "@radix-ui/react-menubar": "1.0.4",
    "@radix-ui/react-popover": "1.0.7",
    "@radix-ui/react-progress": "1.0.3",
    "@radix-ui/react-radio-group": "1.1.3",
    "@radix-ui/react-scroll-area": "1.0.5",
    "@radix-ui/react-select": "2.0.0",
    "@radix-ui/react-separator": "1.0.3",
    "@radix-ui/react-slider": "1.1.2",
